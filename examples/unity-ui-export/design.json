    "colorMode": "RGB"
  },
  "groups": [
    "UI_Panel_01",
    "UI_Button_Primary",
    "UI_Button_Secondary",
    "UI_Icon_Coin",
    "UI_Icon_Star",
    "UI_HUD_Base"
