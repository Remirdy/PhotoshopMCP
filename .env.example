# ─── Local Bridge ──────────────────────────────────────────────────────────────
# Port for the local bridge HTTP + WebSocket server
BRIDGE_PORT=47831

# Shared secret between MCP server and UXP plugin.
# Generate with: openssl rand -hex 32
REMIRDY_BRIDGE_TOKEN=change_me_generate_a_real_secret

# ─── MCP Server ────────────────────────────────────────────────────────────────
# URL of local bridge (default: http://localhost:47831)
BRIDGE_URL=http://localhost:47831

# Enable mock mode when Photoshop plugin is not connected (true/false)
MOCK_MODE=false

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ─── Export Paths ──────────────────────────────────────────────────────────────
# Default folder where exports and job logs are stored
REMIRDY_WORKSPACE=/tmp/remirdy-workspace

# ─── Security ──────────────────────────────────────────────────────────────────
# Comma-separated absolute folder paths allowed as asset sources
ALLOWED_ASSET_FOLDERS=/tmp/remirdy-workspace/assets

# Allow dangerous batchPlay descriptors (NEVER true in production)
ALLOW_DANGEROUS_BATCHPLAY=false
